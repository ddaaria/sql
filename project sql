--6.calculam costul total pentru fiecare rezervare facuta
set serveroutput on
declare
    cursor c is select dr.id_rezervare, tc.denumire_camera, (dr.data_checkout-dr.data_checkin) as nr_nopti, tc.pret_noapte,(dr.data_checkout-dr.data_checkin)*tc.pret_noapte as cost_total
                from detalii_rezervare dr, camere c, tipuri_camere tc
                where dr.id_camera = c.id_camera
                and c.id_tip = tc.id_tip;
    v_id_rez   detalii_rezervare.id_rezervare%TYPE;
    v_denumire tipuri_camere.denumire_camera%TYPE;
    v_nopti    NUMBER;
    v_pret     tipuri_camere.pret_noapte%TYPE;
    v_total    NUMBER;
begin
    open c;
     loop
        fetch c into v_id_rez, v_denumire, v_nopti, v_pret, v_total;
     exit when c%notfound;
        dbms_output.put_line('Rezervarea ' || v_id_rez || '  ' || v_denumire || '  pentru ' || v_nopti || ' nopti  ' || v_pret || ' lei = Total: ' || v_total || ' lei.');
    end loop;
    if c%rowcount=0 then
        dbms_output.put_line('Nu exista detalii de rezervare in baza de date.');
    else
        dbms_output.put_line('Au fost generate ' || c%rowcount || ' note de plata.');
    end if;

    close c;
end;
/
 
