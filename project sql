--2. dam bonusuri angajatilor, daca au salariul mai mare de 10000 facem o exceptie pt ca salariul este prea mare pt bugetul alocat salariatilor

SET SERVEROUTPUT ON;
DECLARE
    CURSOR c IS select id_angajat, nume, salariu 
                         from angajati_hotel;
    
    v_salariu_nou angajati_hotel.salariu%TYPE;
    buget_depasit EXCEPTION; 
    
BEGIN 
    FOR i IN c LOOP
        v_salariu_nou := i.salariu * 1.25;
 
        IF v_salariu_nou > 10000 THEN

            RAISE buget_depasit; 
        ELSE
            DBMS_OUTPUT.PUT_LINE('Angajat: ' || i.nume || ' - Salariu marit: ' || v_salariu_nou);
        END IF;
        
    END LOOP;

EXCEPTION
    WHEN buget_depasit THEN
        DBMS_OUTPUT.PUT_LINE(' S-a oprit procesarea!');
        DBMS_OUTPUT.PUT_LINE('Creșterile au depășit salariul maxim admis (10.000 RON) pentru un angajat.');
    WHEN OTHERS THEN
         DBMS_OUTPUT.PUT_LINE('Eroare generală: ' );
END;
/


--3. mutam o rezervare de pe numele unui turist pe numele altui turist
SET SERVEROUTPUT ON;
ACCEPT r PROMPT 'Introduceti ID-ul rezervarii pe care doriti sa o mutati: '
ACCEPT n PROMPT 'Introduceti ID-ul noului turist care preia rezervarea: '

DECLARE
    v_id_rez  rezervari.id_rezervare%TYPE := &r;
    v_id_nou  turisti.id_turist%TYPE := &n;

    turist_inexistent EXCEPTION;
    PRAGMA EXCEPTION_INIT(turist_inexistent, -2291);
    
BEGIN
    UPDATE rezervari
    SET id_turist = v_id_nou
    WHERE id_rezervare = v_id_rez;
    IF SQL%ROWCOUNT = 0 THEN
        DBMS_OUTPUT.PUT_LINE('Nu s-a facut nicio modificare. Rezervarea cu ID-ul ' || v_id_rez || ' nu exista.');
    ELSE
        DBMS_OUTPUT.PUT_LINE('Rezervarea a fost transferata cu succes catre turistul cu ID: ' || v_id_nou);
    END IF;
    
    ROLLBACK;
    
EXCEPTION
    WHEN turist_inexistent THEN
        DBMS_OUTPUT.PUT_LINE(' Transferul a esuat!');
        DBMS_OUTPUT.PUT_LINE('Motiv: Turistul cu ID-ul ' || v_id_nou || ' nu exista in nomenclatorul de turisti.');
        DBMS_OUTPUT.PUT_LINE('Mesaj tehnic: ' || SQLERRM);
END;
/



--4.vedem daca un turist poate sa si anuleze rezervarea in functie de politica(trebuie sa fie cu cel putin inainte de checkin)
SET SERVEROUTPUT ON;
ACCEPT r PROMPT 'Introduceti ID-ul rezervarii pe care doriti sa o anulati: '

DECLARE
    v_id             rezervari.id_rezervare%TYPE := &r;
    v_data_checkin   detalii_rezervare.data_checkin%TYPE;
    v_denumire_cam   tipuri_camere.denumire_camera%TYPE;
    v_zile_ramase    NUMBER;
BEGIN
    select dr.data_checkin, tc.denumire_camera 
    into v_data_checkin, v_denumire_cam
    from detalii_rezervare dr, camere c, tipuri_camere tc
    where dr.id_camera = c.id_camera 
      and c.id_tip = tc.id_tip
      and dr.id_rezervare = v_id;
      
    v_zile_ramase := TRUNC(v_data_checkin) - TRUNC(SYSDATE);
    
    DBMS_OUTPUT.PUT_LINE('Rezervare gasita pentru camera: ' || v_denumire_cam);
    DBMS_OUTPUT.PUT_LINE('Data check-in: ' || TO_CHAR(v_data_checkin, 'DD-MM-YYYY') || ' (in ' || v_zile_ramase || ' zile).');
 
    IF v_zile_ramase < 3 THEN
        RAISE_APPLICATION_ERROR(-20010, 'POLITICA HOTEL: Anularea respinsa! Au ramas mai putin de 3 zile pana la check-in.');
    ELSE
        DBMS_OUTPUT.PUT_LINE('SUCCES: Rezervarea a fost anulata fara penalizari.');
    END IF;

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('EROARE CAUTARE: Nu am gasit nicio rezervare cu ID-ul ' || v_id || ' in sistem.');
END;
/






