--2.Afisam detaliile camerelor de pe un anumit etaj
set serveroutput on 
declare     
    
    CURSOR c(p camere.etaj%type ) is select  c.id_camera, c.vedere_mare, tc.denumire_camera, tc.pret_noapte, tc.capacitate 
                from camere c, tipuri_camere tc
                where c.id_tip=tc.id_tip
                and etaj=p;
    v_idc camere.id_camera%type;
    v_vm camere.vedere_mare%type;
    v_dc tipuri_camere.denumire_camera%type;
    v_pn tipuri_camere.pret_noapte%type;
    v_cap tipuri_camere.capacitate%type;
    
begin
    open c(&p);
    loop
