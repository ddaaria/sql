create table tipuri_camere ( 
id_tip number(3) primary key, 
denumire_camera varchar2(30) not null,
constraint ck_camera_valida check (denumire_camera in ('STANDARD', 'DELUXE', 'SUITE')),
pret_noapte number (6,2), 
constraint ck_pret check (pret_noapte>0), 
capacitate number (2)
);

create table camere( 
id_camera number(4) primary key, 
etaj number(2) not null,
vedere_mare varchar2(2) check (vedere_mare in('DA', 'NU')),
id_tip number (3),
constraint fk_tip_camera foreign key (id_tip) references tipuri_camere(id_tip)
);

create table turisti( 
id_turist number(5) primary key,
nume varchar2(20) not null,
prenume varchar2(30) not null, 
nr_telefon varchar2(15),
email varchar2(50) unique,
constraint ck_email_valid check (email like '%@%')
);

create table angajati_hotel( 
id_angajat number(6) primary key, 
nume varchar2(20) not null,
prenume varchar2(30) not null,
functie varchar(20) not null,
salariu number (8,2),
data_angajare date default sysdate,
constraint ck_functie check (functie in ('Manager', 'Receptionist', 'Menajera')),
id_manager number (5),
constraint fk_manager_angajat foreign key (id_manager) references angajati_hotel(id_angajat)
);

create table rezervari(
id_rezervare number(7) primary key,
data_rezervare date default sysdate,
modalitate_plata varchar2(2) check (modalitate_plata in ('CASH', 'CARD')),
id_turist number (5), 
id_angajat number (6),
constraint fk_turisti_rezervari foreign key (id_turist) references turisti(id_turist), 
constraint fk_angajati_rezervari foreign key (id_angajat) references angajati_hotel(id_angajat)
);

create table detalii_rezervare( 
id_rezervare number (7) ,
id_camera number (4), 
data_checkin date, 
data_checkout date,
constraint ck_data check(data_checkout > data_checkin),
constraint pk_detalii_rezervare primary key(id_rezervare, id_camera),
constraint fk_rezervari_detalii foreign key (id_rezervare) references rezervari(id_rezervare), 
constraint fk_camere_detalii foreign key (id_camera) references camere(id_camera)
);


