--STRUCTURI DE CONTROL:
--1. vom parcurge toti angajatii hotelului si vom afisa salariul si functia lor
SET SERVEROUTPUT ON;
DECLARE
    v_salariu angajati_hotel.salariu%type;
    v_nume angajati_hotel.nume%type;
    v_functie angajati_hotel.functie%type;
    i number not null:=1;
    v_min angajati_hotel.id_angajat%type;
    v_max v_min%type;
BEGIN
    select min(id_angajat), max(id_angajat)
    into v_min, v_max
    from angajati_hotel;
    i:=v_min;
    FOR i IN v_min..v_max LOOP
        select nume, salariu, functie
        into v_nume, v_salariu, v_functie
        from angajati_hotel
        where id_angajat= i;
        dbms_output.put_line(i||' - '||v_nume||' este: '||v_functie||' si are salariul: ' ||v_salariu);
    END LOOP;

END;
/

--2.Vom vedea care este salariul angajatului cu id ul citit de la tastatura, in functie de salariul lui,
--vom calcula si recomanda o marire de salariu

SET SERVEROUTPUT ON;
DECLARE
    v_sal angajati_hotel.salariu%type;
    v_nume angajati_hotel.nume%type;
    v_prenume angajati_hotel.prenume%type;
    v_id angajati_hotel.id_angajat%type:=&ida;
BEGIN
    select nume, prenume, salariu
    into v_nume, v_prenume, v_sal
    from angajati_hotel
    where id_angajat=v_id;
    dbms_output.put_line(v_nume||' '||v_prenume||' are salariul: ' ||v_sal);
    
    if v_sal < 3000 then 
        dbms_output.put_line('RECOMAND MARIRE DE 15%');
    elsif v_sal between 3000 and 5000 then 
        dbms_output.put_line('RECOMAND MARIRE DE 10%');
    else
        dbms_output.put_line('RECOMAND MARIRE DE 5%');
    end if;
END;
/

--3.parcurgem toti turistii si afisam turistii care au nr de telefon care se termina in 9
SET SERVEROUTPUT ON;
DECLARE 
    v_nume turisti.nume%type;
    v_prenume turisti.prenume%type;
    v_tel turisti.nr_telefon%type;
    v_min turisti.id_turist%type;
    v_max v_min%type;
    t number not null:= 1;
BEGIN
    select min(id_turist), max(id_turist)
    into v_min, v_max
    from turisti;
    t:=v_min;
    LOOP
        select nume, prenume, nr_telefon
        into v_nume, v_prenume, v_tel
        from turisti
        where id_turist=t;
        
        if v_tel like '%9' then
            dbms_output.put_line(v_nume|| ' ' ||v_prenume||' are un numar de telefon care se termina in 9: ' ||v_tel);
        end if;
        
        t:=t+1;
        EXIT WHEN t>v_max;
    END LOOP;
END;
/



